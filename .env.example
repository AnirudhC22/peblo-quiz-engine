# ============================================================
# Peblo AI Quiz Engine — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# LLM Provider — gemini is FREE via Google AI Studio
# Options: gemini | openai | anthropic
LLM_PROVIDER=gemini

# Google Gemini FREE tier
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here 
GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Alternative LLM providers (optional, remove # to activate)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Database — SQLite requires no setup
DATABASE_URL=sqlite:///./peblo_quiz.db
# PostgreSQL alternative:
# DATABASE_URL=postgresql://user:password@localhost:5432/peblo_quiz

# File upload directory
UPLOAD_DIR=./uploads
